```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/
*.o
*.obj
*.class
*.exe
*.dll
*.so
*.a
*.out

# Dependencies
vendor/
node_modules/
.env
.env.local
.env.*

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Editors
.vscode/
.idea/

# Build directories
dist/
build/
target/
coverage/
htmlcov/
*.coverage

# System files
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
```